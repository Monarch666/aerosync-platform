# AeroSync Backend — Environment Configuration
# Copy this file to .env and adjust values as needed.
# .env is gitignored and will never be committed.

# ── Application ─────────────────────────────────────────────────────────────
APP_NAME="AeroSync Satellite Ground Station"
APP_VERSION="1.0.0"
HOST=0.0.0.0
PORT=5001
DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./aerosync.db

# ── Observer Location (decimal degrees) ──────────────────────────────────────
OBSERVER_LATITUDE=28.6139
OBSERVER_LONGITUDE=77.2090
OBSERVER_ALTITUDE_M=216

# ── Pass Prediction ────────────────────────────────────────────────────────
MIN_ELEVATION_DEGREES=10
PASS_LOOKAHEAD_HOURS=24

# ── TLE Sync ─────────────────────────────────────────────────────────────────
TLE_REFRESH_INTERVAL_MINUTES=60
